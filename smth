import org.apache.commons.csv.CSVFormat;
import org.apache.commons.csv.CSVPrinter;
import org.apache.poi.ss.usermodel.*;
import java.io.*;
import java.util.ArrayList;
import java.util.List;
import java.util.Properties;
import java.util.logging.Level;
import java.util.logging.Logger;

public class ExcelMethods {

    private static final Logger logger = Logger.getLogger(ExcelMethods.class.getName());
    private String directoryPath;
    private Workbook workbook;

    // Конструктор инициализирует директорию и Workbook
    public ExcelMethods(String filePath, String directoryPath) throws IOException {
        this.directoryPath = directoryPath != null ? directoryPath : loadDefaultDirectory();
        this.workbook = openWorkbook(filePath);
    }

    /**
     * Метод для загрузки пути к директории из файла конфигурации (properties).
     *
     * @return Путь к директории по умолчанию.
     * @throws IOException Если не удается прочитать файл конфигурации.
     */
    private String loadDefaultDirectory() throws IOException {
        Properties properties = new Properties();
        try (InputStream input = new FileInputStream("config.properties")) {
            properties.load(input);
        }
        return properties.getProperty("default.directory");
    }

    /**
     * Метод для получения списка всех листов из Excel-файла.
     *
     * @return Список имен листов.
     */
    public List<String> getSheetList() {
        List<String> sheetNames = new ArrayList<>();
        for (int i = 0; i < workbook.getNumberOfSheets(); i++) {
            sheetNames.add(workbook.getSheetName(i));
        }
        return sheetNames;
    }

    /**
     * Метод для открытия Excel-файла по указанному пути.
     *
     * @param filePath Путь к файлу Excel.
     * @return Объект Workbook, представляющий файл Excel.
     * @throws IOException Если файл не найден или не может быть прочитан.
     */
    private Workbook openWorkbook(String filePath) throws IOException {
        try (FileInputStream fis = new FileInputStream(filePath)) {
            return WorkbookFactory.create(fis);
        } catch (FileNotFoundException e) {
            logger.log(Level.SEVERE, "File can't be found: " + filePath, e);
            throw e;
        } catch (IOException e) {
            logger.log(Level.SEVERE, "Can't read file: " + filePath, e);
            throw e;
        }
    }

    /**
     * Метод для создания пустых CSV файлов в указанной директории.
     *
     * @param neededCSVFiles Список имен файлов для создания.
     * @throws IOException Если возникают ошибки при создании файлов.
     */
    public void createFiles(List<String> neededCSVFiles) throws IOException {
        for (String neededCSVFile : neededCSVFiles) {
            String fileNameCSV = directoryPath + File.separator + neededCSVFile + ".csv";
            File csvFile = new File(fileNameCSV);
            if (!csvFile.exists()) {
                try (FileWriter writer = new FileWriter(csvFile)) {
                    logger.info("CSV file " + fileNameCSV + " created successfully.");
                } catch (IOException e) {
                    logger.log(Level.SEVERE, "Error creating CSV file: " + neededCSVFile, e);
                }
            }
        }
    }

    /**
     * Метод для записи данных в уже созданные CSV файлы из Excel-листов.
     *
     * @param requiredListToGenerateCSV Список листов, которые нужно записать в CSV.
     * @throws IOException Если возникают ошибки при записи данных.
     */
    public void writeDataToCSVFiles(List<String> requiredListToGenerateCSV) throws IOException {
        List<String> allSheetsList = getSheetList();
        for (String requiredSheet : requiredListToGenerateCSV) {
            if (allSheetsList.contains(requiredSheet)) {
                writeSheetToCSV(requiredSheet);
            }
        }
    }

    /**
     * Вспомогательный метод для записи данных одного листа Excel в CSV файл.
     *
     * @param sheetName Имя листа, который нужно записать.
     * @throws IOException Если возникают ошибки при записи данных.
     */
    private void writeSheetToCSV(String sheetName) throws IOException {
        Sheet sheet = workbook.getSheet(sheetName);
        String csvFilePath = directoryPath + File.separator + sheetName + ".csv";
        File csvFile = new File(csvFilePath);

        if (csvFile.exists() && csvFile.canWrite()) {
            try (BufferedWriter writer = new BufferedWriter(new FileWriter(csvFile, true));
                 CSVPrinter csvPrinter = new CSVPrinter(writer, CSVFormat.DEFAULT)) {

                for (int rowIndex = 0; rowIndex <= sheet.getLastRowNum(); rowIndex++) {
                    Row row = sheet.getRow(rowIndex);
                    if (row == null) continue;

                    List<String> cellValues = new ArrayList<>();
                    for (int cellIndex = 0; cellIndex < row.getPhysicalNumberOfCells(); cellIndex++) {
                        Cell cell = row.getCell(cellIndex);
                        String validatedValue = validateCellValue(cell);
                        cellValues.add(validatedValue);
                    }
                    csvPrinter.printRecord(cellValues);
                }
                logger.info("Data written to CSV: " + csvFilePath);
            } catch (IOException e) {
                logger.log(Level.SEVERE, "Error writing to CSV: " + sheetName, e);
                throw e;
            }
        } else {
            logger.warning("CSV file " + csvFilePath + " cannot be written.");
        }
    }

    /**
     * Метод для валидации данных в ячейке перед записью в CSV.
     * Проверяет тип данных и их корректность.
     *
     * @param cell Ячейка, которую нужно валидировать.
     * @return Валидированное строковое значение для записи в CSV.
     */
    private String validateCellValue(Cell cell) {
        if (cell == null) {
            return ""; // Если ячейка пустая, возвращаем пустую строку
        }
        switch (cell.getCellType()) {
            case STRING:
                return cleanString(cell.getStringCellValue());
            case NUMERIC:
                if (DateUtil.isCellDateFormatted(cell)) {
                    return cell.getDateCellValue().toString(); // Форматируем дату
                } else {
                    return Double.toString(cell.getNumericCellValue()); // Форматируем число
                }
            case BOOLEAN:
                return Boolean.toString(cell.getBooleanCellValue());
            case BLANK:
                return ""; // Пустая ячейка
            default:
                return cleanString(cell.toString()); // По умолчанию преобразуем в строку
        }
    }

    /**
     * Метод для очистки строковых значений от недопустимых символов.
     * Убирает запятые, которые могут конфликтовать с CSV-форматом.
     *
     * @param value Строка, которую нужно очистить.
     * @return Очищенное значение строки.
     */
    private String cleanString(String value) {
        if (value == null) return "";
        return value.replace(",", " "); // Заменяем запятые на пробелы
    }
}
