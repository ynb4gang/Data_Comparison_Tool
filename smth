import org.apache.commons.csv.CSVFormat;
import org.apache.poi.ss.usermodel.*;
import org.apache.poi.xssf.usermodel.XSSFWorkbook;
import org.apache.commons.csv.CSVPrinter;

import java.io.*;
import java.util.ArrayList;

public class ExcelMethods {
    public static ArrayList<String> getSheetList(String filepath) throws IOException {
        ArrayList<String> sheetNames = new ArrayList<>();

        FileInputStream fileInputStream = new FileInputStream(filepath);
        Workbook workbook = new XSSFWorkbook(fileInputStream);

        for (int i = 0; i < workbook.getNumberOfSheets(); i++) {
            sheetNames.add(workbook.getSheetName(i));
        }
        workbook.close();
        fileInputStream.close();

        return sheetNames;
    }

    protected static Workbook openWorkbook(String filePath) throws FileNotFoundException {
        Workbook workbook = null;
        try (FileInputStream fis = new FileInputStream(filePath)) {
            workbook = WorkbookFactory.create(fis);
        } catch (FileNotFoundException e) {
            System.err.println("File can't be find: " + filePath);
            throw e;
        } catch (IOException e) {
            System.err.println("Cant read file: " + filePath);
        }
        return workbook;
    }

    //доделать метод чтобы сначала создал все файлы
    protected static String createFiles(ArrayList<String> neededCSVFiles ) throws IOException {
        for (int i = 0; i < neededCSVFiles.size(); i++) {
            String fileNameCSV = neededCSVFiles.get(i) + ".csv";
            FileWriter writer = null;
            try {
                writer = new FileWriter(fileNameCSV);
            } catch (IOException e) {
                System.err.println("Error to create CSV file: " + e.getMessage());
            }
            saveFile(writer, fileNameCSV);
        }
        return "All required CSV files created and saved";
    }

    protected static void saveFile(FileWriter fileWriter, String filename) throws IOException {
        if (fileWriter != null) {
            try {
                fileWriter.flush();
                fileWriter.close();
                System.out.println("CSV file " + filename+ ".csv " +"saved successfully.");
            } catch (IOException e) {
                System.err.println("Error saving CSV file: " + e.getMessage());
            }
        }
    }
    protected static void createCSVsToAllMapRequiredLists(Workbook workbook, ArrayList<String> allSheetsList, ArrayList<String> requiredListToGenerateCSV, FileWriter fileWriter , String filepathToSave) throws IOException {
        for (int i = 0; i < requiredListToGenerateCSV.size(); i++) {
            if(allSheetsList.contains(requiredListToGenerateCSV.get(i))) {
                FileWriter csvFile = ExcelMethods.
                Sheet neededSheet = workbook.getSheet(requiredListToGenerateCSV.get(i));
                for (int j = 0 ; j < neededSheet.getLastRowNum() + 1; j++ ) {
                    Row row = neededSheet.getRow(j);
                    int numberOfCells = neededSheet.getRow(j).getPhysicalNumberOfCells();
                    for(int k = 0; k < numberOfCells; k++) {
                        Cell cell = row.getCell(k);
                        csvFile.append(cell.toString());
                        csvFile.append(",");
                    }
                    csvFile.append('\n');
                }
                saveFile(csvFile);
            }
        }
    }
