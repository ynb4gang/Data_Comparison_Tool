from pyspark.sql import SparkSession
from pyspark.sql.functions import col, lit, when, coalesce, expr
from pyspark.sql.window import Window
from pyspark.sql.types import IntegerType

# Создаем Spark сессию
spark = SparkSession.builder \
    .appName("TimeSeriesForecasting") \
    .getOrCreate()

# Загрузим данные из CSV файла
df = spark.read.csv("path/to/your/file.csv", header=True, inferSchema=True)

# Вычисляем последнюю колонку с ненулевым значением
last_non_zero_month = None
for i, column in enumerate(df.columns[4:]):  # предполагаем, что первые 4 колонки — это метаданные
    current_col = when(col(column).isNotNull() & (col(column) > 0), lit(i + 1)).otherwise(lit(0))
    if last_non_zero_month is None:
        last_non_zero_month = current_col
    else:
        last_non_zero_month = when(current_col > last_non_zero_month, current_col).otherwise(last_non_zero_month)

# Добавляем колонку с последним ненулевым месяцем
df = df.withColumn("last_non_zero_month", last_non_zero_month.cast(IntegerType()))

# Создаем пустую таблицу для прогнозов на 18 месяцев
forecast_columns = [f'forecast_month_{i+1}' for i in range(18)]
forecast_df = df.select(df.columns[:4])  # Копируем первые 4 колонки (метаданные)
for i in range(18):
    forecast_col = f'forecast_month_{i+1}'
    forecast_df = forecast_df.withColumn(forecast_col, lit(0))

# Вычисляем прогноз
for i in range(18):
    forecast_col = f'forecast_month_{i+1}'
    condition = (col("last_non_zero_month").isNotNull()) & (col("last_non_zero_month") + i <= len(df.columns[4:]))
    forecast_df = forecast_df.withColumn(
        forecast_col, 
        when(condition, col(df.columns[-1]) * (1 + 0.05 * (i + 1))).otherwise(0)
    )

# Сохраняем результаты в файл
forecast_df.write.csv("path/to/save/forecast.csv", header=True)
