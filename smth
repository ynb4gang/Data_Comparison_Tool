from pyspark.sql import SparkSession
from pyspark.sql.functions import lit

# Создание Spark-сессии
spark = SparkSession.builder \
    .appName("Add Empty Columns") \
    .config("spark.executor.memory", "4g") \
    .config("spark.executor.cores", "4") \
    .config("spark.executor.instances", "4") \
    .config("spark.sql.shuffle.partitions", "200") \
    .config("spark.driver.memory", "2g") \
    .getOrCreate()

# Путь к вашему CSV файлу
csv_path = "10cTpok.csv"

# Загрузка CSV файла
df = spark.read.csv(csv_path, header=True, inferSchema=True, sep=';', encoding='UTF-8')

# Добавляем 18 новых пустых столбцов
for i in range(18):
    forecast_col = f'forecast_month_{i+1}'
    df = df.withColumn(forecast_col, lit(None))

# Сохранение результата в CSV файл
output_path = "forecast_output.csv"
df.write.csv(output_path, header=True, sep=';', encoding='UTF-8', mode='overwrite')

# Завершаем Spark сессию
spark.stop()
