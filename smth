from pyspark.sql import SparkSession
from pyspark.sql.functions import col, when, lit, greatest
from pyspark.sql.types import DoubleType, IntegerType

# Создание Spark-сессии
spark = SparkSession.builder \
    .appName("Time Series Forecasting") \
    .config("spark.executor.memory", "4g") \
    .config("spark.executor.cores", "4") \
    .config("spark.executor.instances", "4") \
    .config("spark.sql.shuffle.partitions", "200") \
    .config("spark.driver.memory", "2g") \
    .getOrCreate()

# Путь к вашему CSV файлу
csv_path = "10cTpok.csv"

# Загрузка CSV файла
df = spark.read.csv(csv_path, header=True, inferSchema=True, sep=';', encoding='UTF-8')

# Замена пустых полей на 0, начиная с 5-го столбца
columns_to_fill = df.columns[4:]
df = df.fillna(0, subset=columns_to_fill)

# Преобразование колонок к числовому типу
for column in columns_to_fill:
    df = df.withColumn(column, col(column).cast(DoubleType()))

# Найти последний месяц с ненулевым значением
last_non_zero_month_expr = lit(None)
for i, column in enumerate(columns_to_fill):
    current_col = when(col(column) > 0, lit(i+1))
    last_non_zero_month_expr = greatest(current_col, last_non_zero_month_expr)

# Добавляем столбец с последним ненулевым месяцем
df = df.withColumn("last_non_zero_month", last_non_zero_month_expr.cast(IntegerType()))

# Динамическое создание прогноза
for i in range(18):
    forecast_col = f'forecast_month_{i+1}'

    # Инициализация выражения прогноза как null
    forecast_expr = lit(0)

    # Перебираем каждый столбец и добавляем соответствующее условие в выражение
    for j, column in enumerate(columns_to_fill):
        forecast_expr = when(
            col("last_non_zero_month") == (j + 1), 
            col(column) * (1 + 0.05 * (i + 1))
        ).otherwise(forecast_expr)

    df = df.withColumn(forecast_col, forecast_expr)

# Удаляем временные колонки
df = df.drop("last_non_zero_month")

# Сохранение результата в CSV файл
output_path = "forecast_output.csv"
df.write.csv(output_path, header=True, sep=';', encoding='UTF-8', mode='overwrite')

# Завершаем Spark сессию
spark.stop()
